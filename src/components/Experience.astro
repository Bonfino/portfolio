---

---

<section id="experience" class="py-16 px-4 container mx-auto">
  <div class="flex flex-col gap-10">
    <div>
      <h2 class="text-2xl font-medium tracking-widest uppercase text-white">
        Experience
      </h2>

      <div class="flex items-center gap-6 mt-2">
        <button
          data-tab="work"
          class="tab-btn text-base font-light tracking-wide pb-0.5 transition-colors duration-200
         text-[#F8F8F8] border-b border-[#F8F8F8] cursor-pointer hover:text-[#F8F8F8]"
        >
          Work
        </button>
        <button
          data-tab="education"
          class="tab-btn text-base font-light tracking-wide pb-0.5 transition-colors duration-200
         text-[#8c8c8c] border-b border-transparent cursor-pointer hover:text-[#F8F8F8]"
        >
          Education
        </button>
      </div>
    </div>

    <div class="grid">
      <div id="tab-work" class="[grid-area:1/1] flex flex-col gap-10">
        <div class="flex flex-col gap-2">
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-xl text-[#F8F8F8] font-medium">TWOW</span>
            <span class="text-sm text-[#8c8c8c] font-light tabular-nums"
              >Nov 2025 - May 2026</span
            >
          </div>
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-base text-[#8c8c8c] font-light italic"
              >Full Stack Web Developer</span
            >
            <span class="text-sm text-[#8c8c8c] font-light"
              >Internship · Genova</span
            >
          </div>
          <div class="flex flex-col gap-1.5 mt-1">
            <p
              class="text-lg font-light text-[#8c8c8c] leading-relaxed pl-3 border-l border-[#2a2a2a]"
            >
              Built websites in <span class="text-[#F8F8F8]">WordPress</span> and
              <span class="text-[#F8F8F8]"> PHP</span> using <span
                class="text-[#F8F8F8]">JavaScript</span
              >, <span class="text-[#F8F8F8]">HTML</span>, <span
                class="text-[#F8F8F8]">CSS</span
              > and <span class="text-[#F8F8F8]">SQL</span>. Developed <span
                class="text-[#F8F8F8]">RESTful API</span
              > middleware with <span class="text-[#F8F8F8]">Laravel</span>.
            </p>
            <p
              class="text-lg font-light text-[#8c8c8c] leading-relaxed pl-3 border-l border-[#2a2a2a]"
            >
              Maintained existing sites ensuring long-term <span
                class="text-[#F8F8F8]">stability</span
              > and <span class="text-[#F8F8F8]">security</span>. Conducted <span
                class="text-[#F8F8F8]">accessibility</span
              > audits and applied <span class="text-[#F8F8F8]">SEO</span> best practices.
            </p>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-xl text-[#F8F8F8] font-medium">Applause</span>
            <span class="text-sm text-[#8c8c8c] font-light tabular-nums"
              >Jul 2023 - Present</span
            >
          </div>
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-base text-[#8c8c8c] font-light italic"
              >QA Tester → Team Test Lead</span
            >
            <span class="text-sm text-[#8c8c8c] font-light">Remote</span>
          </div>
          <div class="flex flex-col gap-1.5 mt-1">
            <p
              class="text-lg font-light text-[#8c8c8c] leading-relaxed pl-3 border-l border-[#2a2a2a]"
            >
              <span class="text-[#F8F8F8]">Top 2%</span> tester with hands-on experience
              in <span class="text-[#F8F8F8]">functional testing</span> and <span
                class="text-[#F8F8F8]">regression testing</span
              > across web and mobile products.
            </p>
            <p
              class="text-lg font-light text-[#8c8c8c] leading-relaxed pl-3 border-l border-[#2a2a2a]"
            >
              Promoted to <span class="text-[#F8F8F8]">Team Test Lead</span> (Jun
              2025 - Nov 2025): coordinated test cycles and supervised report quality
              across the team.
            </p>
          </div>
        </div>
      </div>

      <div
        id="tab-education"
        class="[grid-area:1/1] flex flex-col gap-10 invisible pointer-events-none"
      >
        <div class="flex flex-col gap-0.5">
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-xl text-[#F8F8F8] font-medium"
              >ITS Liguria</span
            >
            <span class="text-sm text-[#8c8c8c] font-light tabular-nums"
              >Nov 2024 - Jul 2026</span
            >
          </div>
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-base text-[#8c8c8c] font-light italic"
              >AR/VR Game Developer</span
            >
            <span class="text-sm text-[#8c8c8c] font-light">--</span>
          </div>
        </div>

        <div class="flex flex-col gap-0.5">
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-xl text-[#F8F8F8] font-medium"
              >University of Genova</span
            >
            <span class="text-sm text-[#8c8c8c] font-light tabular-nums"
              >Sep 2022 - Aug 2024</span
            >
          </div>
          <span class="text-base text-[#8c8c8c] font-light italic"
            >Computer Engineering</span
          >
        </div>

        <div class="flex flex-col gap-0.5">
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-xl text-[#F8F8F8] font-medium"
              >IIS Majorana - Giorgi</span
            >
            <span class="text-sm text-[#8c8c8c] font-light tabular-nums"
              >Sep 2017 - Jun 2022</span
            >
          </div>
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-base text-[#8c8c8c] font-light italic"
              >Computer Science & Telecommunications</span
            >
            <span class="text-sm text-[#8c8c8c] font-light">94/100</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
  const tabs: Record<string, HTMLElement | null> = {
    work: document.getElementById("tab-work"),
    education: document.getElementById("tab-education"),
  };

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.tab as string;

      buttons.forEach((b) => {
        const isActive = b.dataset.tab === target;
        b.classList.toggle("text-[#F8F8F8]", isActive);
        b.classList.toggle("border-[#F8F8F8]", isActive);
        b.classList.toggle("text-[#8c8c8c]", !isActive);
        b.classList.toggle("border-transparent", !isActive);
      });

      Object.entries(tabs).forEach(([key, el]) => {
        if (!el) return;
        const isActive = key === target;
        el.classList.toggle("invisible", !isActive);
        el.classList.toggle("pointer-events-none", !isActive);
      });
    });
  });
</script>
